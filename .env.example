# Application
APP_NAME=ai-platform
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=debug

# OpenRouter LLM
OPENROUTER_API_KEY=##############
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=#######

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://aiplatform:aiplatform@localhost:5432/aiplatform

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=faq_documents

# Server
HOST=0.0.0.0
PORT=8000
