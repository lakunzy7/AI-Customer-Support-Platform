# Application
APP_NAME=ai-platform
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=debug

# LLM Provider (Groq — free, fast inference)
LLM_API_KEY=your-groq-api-key-here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://aiplatform:aiplatform@localhost:5432/aiplatform

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=faq_documents

# Server
HOST=0.0.0.0
PORT=8000
